generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  MEMBER
}

model User {
  id                String            @id @default(cuid())
  email             String            @unique
  passwordHash      String
  name              String?
  resetToken        String?           @unique
  resetTokenExpires DateTime?         @db.Timestamptz
  createdAt         DateTime          @default(now()) @db.Timestamptz
  memberships       WorkspaceMember[]
  sessions          Session[]
  tasks             Task[]
  attendance        AttendanceLog[]
  entries           TimeEntry[]
  orgMemberships    OrganizationMember[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  workspaceId  String
  role         Role
  refreshToken String   @unique
  expiresAt    DateTime @db.Timestamptz
  createdAt    DateTime @default(now()) @db.Timestamptz
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId, workspaceId])
  @@index([expiresAt])
}

model Workspace {
  id             String            @id @default(cuid())
  name           String
  timezone       String            @default("UTC")
  customDomain   String?           @unique
  createdAt      DateTime          @default(now()) @db.Timestamptz
  organizationId String?
  organization   Organization?     @relation(fields: [organizationId], references: [id])
  members        WorkspaceMember[]
  teams          Team[]
  projects       Project[]
  tasks          Task[]
  tags           Tag[]
  clients        Client[]
  entries        TimeEntry[]
  timers         RunningTimer[]
  breaks         BreakSession[]
  policies       WorkspacePolicy[]
  invites        Invite[]
  audits         AuditLog[]
  attendance     AttendanceLog[]

  @@index([organizationId])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        Role      @default(MEMBER)
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Invite {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  role        Role      @default(MEMBER)
  token       String    @unique
  expiresAt   DateTime  @db.Timestamptz
  acceptedAt  DateTime? @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, email])
  @@index([expiresAt])
}
model Team {
  id           String        @id @default(cuid())
  workspaceId  String
  name         String
  deletedAt    DateTime?     @db.Timestamptz
  createdAt    DateTime      @default(now()) @db.Timestamptz
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  members      TeamMember[]
  projectTeams ProjectTeam[]

  @@index([workspaceId])
  @@index([deletedAt])
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model Project {
  id           String        @id @default(cuid())
  workspaceId  String
  clientId     String?
  name         String
  color        String        @default("#059669")
  archived     Boolean       @default(false)
  deletedAt    DateTime?     @db.Timestamptz
  createdAt    DateTime      @default(now()) @db.Timestamptz
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  client       Client?       @relation(fields: [clientId], references: [id])
  entries      TimeEntry[]
  projectTeams ProjectTeam[]

  @@index([workspaceId])
  @@index([clientId])
  @@index([deletedAt])
}

model Task {
  id          String      @id @default(cuid())
  workspaceId String
  userId      String?
  projectId   String?
  name        String
  status      String      @default("To Do")
  priority    String      @default("Low")
  deletedAt   DateTime?   @db.Timestamptz
  createdAt   DateTime    @default(now()) @db.Timestamptz
  workspace   Workspace   @relation(fields: [workspaceId], references: [id])
  user        User?       @relation(fields: [userId], references: [id])
  entries     TimeEntry[]

  @@index([workspaceId])
  @@index([projectId])
  @@index([userId])
  @@index([deletedAt])
}

model Tag {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  color       String    @default("#6B7280")
  deletedAt   DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([deletedAt])
}

model Client {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  email       String?
  deletedAt   DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  projects    Project[]

  @@index([workspaceId])
  @@index([deletedAt])
}

model TimeEntry {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  projectId   String?
  taskId      String?
  tagId       String?
  description String
  startedAt   DateTime  @db.Timestamptz
  endedAt     DateTime? @db.Timestamptz
  billable    Boolean   @default(false)
  approved    Boolean   @default(false)
  invoiced    Boolean   @default(false)
  createdAt   DateTime  @default(now()) @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id])
  task        Task?     @relation(fields: [taskId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, userId, startedAt])
  @@index([workspaceId, startedAt])
  @@index([workspaceId, projectId])
  @@index([taskId])
  @@index([tagId])
}

model RunningTimer {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String    @unique
  entryId     String    @unique
  startedAt   DateTime  @default(now()) @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, userId])
}

model BreakSession {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  startedAt   DateTime  @default(now()) @db.Timestamptz
  endedAt     DateTime? @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, userId, startedAt])
}
model WorkspacePolicy {
  id                    String    @id @default(cuid())
  workspaceId           String    @unique
  forceTimer            Boolean   @default(false)
  idleMinutes           Int       @default(10)
  overtimeHours         Int       @default(8)
  pomodoroMinutes       Int       @default(25)
  breakMinutes          Int       @default(5)
  longRunningMinutes    Int       @default(480)
  reminderEnabled       Boolean   @default(true)
  autoPauseOnIdle       Boolean   @default(false)
  allowSelfRegistration Boolean   @default(true)
  permittedDomains      String    @default("")
  weekStartDay          Int       @default(1)
  fiscalYearStartMonth  Int       @default(1)
  workspace             Workspace @relation(fields: [workspaceId], references: [id])
}

model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  actorUserId String
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  clientIp    String    @default("127.0.0.1")
  userAgent   String    @default("Unknown")
  createdAt   DateTime  @default(now()) @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([actorUserId])
}

model AttendanceLog {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  date        DateTime  @db.Date
  clockInAt   DateTime  @db.Timestamptz
  clockOutAt  DateTime? @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId, date])
}

model Organization {
  id          String            @id @default(cuid())
  name        String
  billingPlan String            @default("ENTERPRISE")
  createdAt   DateTime          @default(now()) @db.Timestamptz
  workspaces  Workspace[]
  orgMembers  OrganizationMember[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  orgId          String
  userId         String
  role           String       @default("ORG_ADMIN")
  organization   Organization @relation(fields: [orgId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([orgId, userId])
  @@index([userId])
}

model ProjectTeam {
  id        String  @id @default(cuid())
  projectId String
  teamId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([projectId, teamId])
  @@index([projectId])
  @@index([teamId])
}


